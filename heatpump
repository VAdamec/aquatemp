#!/bin/bash

set -euo pipefail

path="$(cd "$(dirname "$0")" && pwd)"
settings_file="$path/settings"
cache_dir="$path/tmp"
token_file="$cache_dir/token"
device_file="$cache_dir/device"
info_file="$cache_dir/info"
status_file="$cache_dir/status"
fault_file="$cache_dir/fault"
test_file="$cache_dir/test"
protocol_codes_file="$path/protocol_codes.txt"
cloudurl="https://cloud.linked-go.com:449/crmservice/api"
app_id="16"
lang="en"

setting()
{
	awk -F '\t' -v key="$1" '$1 == key { print $2; exit }' "$settings_file"
}

require_setting()
{
	local value="$1"
	local key="$2"

	if [[ -z "$value" ]]; then
		echo "Missing $key in $settings_file" >&2
		exit 1
	fi
}

hash_password()
{
	local raw="$1"

	if [[ "$raw" =~ ^[0-9a-fA-F]{32}$ ]]; then
		printf '%s' "$raw" | tr '[:upper:]' '[:lower:]'
	else
		printf '%s' "$raw" | openssl dgst -md5 | awk '{print $2}'
	fi
}

curl_json()
{
	local url="$1"
	local payload="${2:-}"
	local token_header="${3:-}"
	local -a cmd

	cmd=(curl -s -H "Content-Type: application/json; charset=utf-8" -X POST)

	if [[ -n "$token_header" ]]; then
		cmd+=(-H "x-token: $token_header")
	fi

	if [[ -n "$payload" ]]; then
		cmd+=(-d "$payload")
	fi

	cmd+=("$url")
	"${cmd[@]}"
}

app_url()
{
	printf '%s/app/%s?lang=%s' "$cloudurl" "$1" "$lang"
}

write_file()
{
	printf '%s\n' "$2" > "$1"
}

cache_is_fresh()
{
	[ -f "$token_file" ] && [ -f "$device_file" ] && [[ "$(find "$token_file" -mmin -1440 | wc -l | tr -d ' ')" -ge 1 ]]
}

load_cache()
{
	token=$(cat "$token_file")
	device=$(cat "$device_file")
}

save_cache()
{
	write_file "$token_file" "$token"
	write_file "$device_file" "$device"
}

load_protocol_codes_json()
{
	if [[ -z "$protocol_codes_json" ]]; then
		protocol_codes_json=$(jq -Rs 'split("\n") | map(select(length > 0 and (startswith("#") | not)))' "$protocol_codes_file")
	fi

	printf '%s' "$protocol_codes_json"
}

refresh_auth()
{
	local login_payload
	local login_response
	local device_response

	require_setting "$username" "username"
	require_setting "$password" "password"

	login_payload=$(jq -nc \
		--arg password "$password_hash" \
		--arg userName "$username" \
		--arg appId "$app_id" \
		'{
			password: $password,
			loginSource: "IOS",
			areaCode: "en",
			appId: $appId,
			type: "2",
			userName: $userName
		}')

	login_response=$(curl_json "$(app_url "user/login")" "$login_payload")
	token=$(jq -r '.objectResult."x-token" // empty' <<<"$login_response")

	if [[ -z "$token" ]]; then
		echo "Login failed" >&2
		jq . <<<"$login_response" >&2
		exit 1
	fi

	device_response=$(curl_json "$(app_url "device/deviceList")" "" "$token")
	device=$(jq -r '.objectResult[0].deviceCode // .objectResult[0].device_code // empty' <<<"$device_response")

	if [[ -z "$device" ]]; then
		echo "Device lookup failed" >&2
		jq . <<<"$device_response" >&2
		exit 1
	fi

	save_cache
}

ensure_auth()
{
	if [[ -n "$token" && -n "$device" ]]; then
		return
	fi

	if cache_is_fresh; then
		load_cache
	else
		refresh_auth
	fi
}

api_post()
{
	local endpoint="$1"
	local payload="${2:-}"
	local response
	local error_code

	ensure_auth
	response=$(curl_json "$(app_url "$endpoint")" "$payload" "$token")
	error_code=$(jq -r '.error_code // empty' <<<"$response")

	if [[ "$error_code" == "-100" ]]; then
		refresh_auth
		response=$(curl_json "$(app_url "$endpoint")" "$payload" "$token")
	fi

	printf '%s' "$response"
}

mqtt_publish()
{
	local topic="$1"
	local payload="$2"
	local -a cmd

	require_setting "$mqtt" "mqttserver"
	require_setting "$mqttport" "mqttport"

	cmd=(mosquitto_pub -r -h "$mqtt" -p "$mqttport" -t "$topic" -m "$payload")

	if [[ -n "$mqttuser" && "$mqttuser" != "none" ]]; then
		cmd+=(-u "$mqttuser")
	fi

	if [[ -n "$mqttpass" && "$mqttpass" != "none" ]]; then
		cmd+=(-P "$mqttpass")
	fi

	"${cmd[@]}"
}

publish_state()
{
	mqtt_publish "homeassistant/$1/${name}_$2/state" "$3"
}

publish_discovery()
{
	mqtt_publish "homeassistant/$1/${name}_$2/config" "$3"
}

clear_discovery()
{
	publish_discovery "$1" "$2" ""
}

publish_basic_discovery()
{
	local component="$1"
	local object_id="$2"
	local label="$3"
	local payload

	payload=$(jq -nc \
		--arg name "$name $label" \
		--arg state_topic "homeassistant/$component/${name}_$object_id/state" \
		'{name: $name, state_topic: $state_topic}')

	publish_discovery "$component" "$object_id" "$payload"
}

publish_measure_discovery()
{
	local component="$1"
	local object_id="$2"
	local label="$3"
	local device_class="$4"
	local unit="$5"
	local payload

	payload=$(jq -nc \
		--arg name "$name $label" \
		--arg state_topic "homeassistant/$component/${name}_$object_id/state" \
		'{name: $name, state_topic: $state_topic}')

	if [[ -n "$device_class" ]]; then
		payload=$(jq -c --arg device_class "$device_class" '. + {device_class: $device_class}' <<<"$payload")
	fi

	if [[ -n "$unit" ]]; then
		payload=$(jq -c --arg unit_of_measurement "$unit" '. + {unit_of_measurement: $unit_of_measurement}' <<<"$payload")
	fi

	publish_discovery "$component" "$object_id" "$payload"
}

publish_switch_discovery()
{
	local payload

	payload=$(jq -nc \
		--arg name "$name Silent" \
		--arg command_topic "homeassistant/switch/${name}_silent/set" \
		--arg state_topic "homeassistant/binary_sensor/${name}_silent/state" \
		'{
			name: $name,
			command_topic: $command_topic,
			state_topic: $state_topic
		}')

	mqtt_publish "homeassistant/switch/${name}_silent/config" "$payload"
}

publish_climate_discovery()
{
	local payload

	payload=$(jq -nc \
		--arg name "$name" \
		--arg current_temperature_topic "homeassistant/sensor/${name}_inlet/state" \
		--arg mode_command_topic "homeassistant/climate/${name}/mode/set" \
		--arg mode_state_topic "homeassistant/sensor/${name}_mode_state/state" \
		--arg temperature_command_topic "homeassistant/climate/${name}/temperature/set" \
		--arg temperature_state_topic "homeassistant/sensor/${name}_readtemp/state" \
		'{
			name: $name,
			current_temperature_topic: $current_temperature_topic,
			mode_command_topic: $mode_command_topic,
			mode_state_topic: $mode_state_topic,
			temperature_command_topic: $temperature_command_topic,
			temperature_state_topic: $temperature_state_topic,
			temperature_unit: "C",
			min_temp: "15",
			max_temp: "55",
			temp_step: "0.5",
			modes: ["off", "heat", "cool", "auto"]
		}')

	mqtt_publish "homeassistant/climate/$name/config" "$payload"
}

device_value()
{
	local file="$1"
	local code="$2"

	jq -r --arg code "$code" '[.objectResult[]? | select(.code == $code) | .value][0] // empty' "$file"
}

binary_state()
{
	case "$1" in
		1|true|TRUE|ON|on) echo ON ;;
		*) echo OFF ;;
	esac
}

mode_state()
{
	local power="$1"
	local mode="$2"

	if [[ "$power" != "1" ]]; then
		echo off
		return
	fi

	case "$mode" in
		0) echo cool ;;
		1) echo heat ;;
		2) echo auto ;;
		*) echo unknown ;;
	esac
}

control_payload()
{
	jq -nc \
		--arg deviceCode "$device" \
		--arg protocolCode "$1" \
		--arg value "$2" \
		'{
			param: [
				{
					deviceCode: $deviceCode,
					protocolCode: $protocolCode,
					value: $value
				}
			]
		}'
}

set_protocol()
{
	local response

	response=$(api_post "device/control" "$(control_payload "$1" "$2")")
	jq . <<<"$response"
}

install_entities()
{
	publish_basic_discovery sensor status "Status"
	publish_basic_discovery binary_sensor power "Power"
	publish_basic_discovery binary_sensor silent "Silent"
	publish_measure_discovery sensor settemp "Settemp" temperature "°C"
	publish_measure_discovery sensor readtemp "Readtemp" temperature "°C"
	publish_measure_discovery sensor dwhtemp "DWHtemp" temperature "°C"
	publish_measure_discovery sensor inlet "Inlet" temperature "°C"
	publish_measure_discovery sensor outlet "Outlet" temperature "°C"
	publish_basic_discovery sensor mode_state "Mode State"
	publish_basic_discovery sensor mode_set "Mode Set"
	publish_basic_discovery sensor error_msg "Error msg"
	publish_basic_discovery sensor is_fault "Is fault"
	publish_measure_discovery sensor ambient "Ambient" temperature "°C"
	publish_measure_discovery sensor coil "Coil" temperature "°C"
	publish_measure_discovery sensor suction "Suction" temperature "°C"
	publish_measure_discovery sensor current "Current" "" ""
	publish_switch_discovery
	publish_climate_discovery
}

uninstall_entities()
{
	clear_discovery sensor status
	clear_discovery binary_sensor power
	clear_discovery binary_sensor silent
	clear_discovery sensor settemp
	clear_discovery sensor readtemp
	clear_discovery sensor dwhtemp
	clear_discovery sensor inlet
	clear_discovery sensor outlet
	clear_discovery sensor mode_state
	clear_discovery sensor mode_set
	clear_discovery sensor error_msg
	clear_discovery sensor is_fault
	clear_discovery sensor ambient
	clear_discovery sensor coil
	clear_discovery sensor suction
	clear_discovery sensor current
	mqtt_publish "homeassistant/switch/${name}_silent/config" ""
	mqtt_publish "homeassistant/climate/$name/config" ""
}

publish_status()
{
	local payload
	local response
	local online
	local is_fault
	local fault_message
	local fault_response

	payload=$(jq -nc --arg deviceCode "$device" '{deviceCode: $deviceCode}')
	response=$(api_post "device/getDeviceStatus" "$payload")
	write_file "$status_file" "$response"

	online=$(jq -r '.objectResult.status // empty' "$status_file")
	is_fault=$(jq -r '.objectResult.is_fault // empty' "$status_file")
	fault_message="No Error"

	if [[ "$is_fault" == "true" ]]; then
		fault_response=$(api_post "device/getFaultDataByDeviceCode" "$payload")
		write_file "$fault_file" "$fault_response"
		fault_message=$(jq -r '[.objectResult[]?.description][0] // "Fault details unavailable"' "$fault_file")
	fi

	publish_state sensor status "$online"
	publish_state sensor is_fault "$is_fault"
	publish_state sensor error_msg "$fault_message"
}

publish_info()
{
	local payload
	local response
	local codes_json
	local power
	local target_temp
	local suction_temp
	local inlet_temp
	local outlet_temp
	local coil_temp
	local ambient_temp
	local mode
	local silent
	local current
	local dwh_temp
	local current_mode

	codes_json=$(load_protocol_codes_json)
	payload=$(jq -nc \
		--arg deviceCode "$device" \
		--arg appId "$app_id" \
		--argjson protocalCodes "$codes_json" \
		'{
			deviceCode: $deviceCode,
			appId: $appId,
			protocalCodes: $protocalCodes
		}')

	response=$(api_post "device/getDataByCode" "$payload")
	write_file "$info_file" "$response"

	power=$(device_value "$info_file" "Power")
	target_temp=$(device_value "$info_file" "R02")
	suction_temp=$(device_value "$info_file" "T01")
	inlet_temp=$(device_value "$info_file" "T02")
	outlet_temp=$(device_value "$info_file" "T03")
	coil_temp=$(device_value "$info_file" "T04")
	ambient_temp=$(device_value "$info_file" "T05")
	mode=$(device_value "$info_file" "Mode")
	silent=$(device_value "$info_file" "Manual-mute")
	current=$(device_value "$info_file" "InputCurrent1")
	dwh_temp=$(device_value "$info_file" "T08")
	current_mode=$(mode_state "$power" "$mode")

	publish_state sensor settemp "$target_temp"
	publish_state sensor readtemp "$target_temp"
	publish_state sensor inlet "$inlet_temp"
	publish_state sensor outlet "$outlet_temp"
	publish_state sensor ambient "$ambient_temp"
	publish_state sensor coil "$coil_temp"
	publish_state sensor suction "$suction_temp"
	publish_state sensor current "$current"
	publish_state sensor dwhtemp "$dwh_temp"
	publish_state sensor mode_state "$current_mode"
	publish_state sensor mode_set "$current_mode"
	publish_state binary_sensor silent "$(binary_state "$silent")"
	publish_state binary_sensor power "$(binary_state "$power")"

	printf 'DWH %s - Heat temp %s\n' "$dwh_temp" "$target_temp"
}

test_protocol()
{
	local payload
	local response

	payload=$(jq -nc \
		--arg deviceCode "$device" \
		--arg protocolCode "$1" \
		'{
			deviceCode: $deviceCode,
			protocolCode: [$protocolCode]
		}')

	response=$(api_post "device/getDataByCode" "$payload")
	write_file "$test_file" "$response"
	jq . "$test_file"
}

set_mode()
{
	case "$1" in
		heat) set_protocol "Mode" "1" ;;
		cool) set_protocol "Mode" "0" ;;
		auto) set_protocol "Mode" "2" ;;
		*)
			echo "Usage: $0 mode {heat|cool|auto}" >&2
			exit 1
			;;
	esac
}

set_silent()
{
	local state

	state=$(printf '%s' "$1" | tr '[:lower:]' '[:upper:]')

	case "$state" in
		ON) set_protocol "Timer_Mute_On_En" "1" ;;
		OFF) set_protocol "Timer_Mute_On_En" "0" ;;
		*)
			echo "Usage: $0 silent {ON|OFF}" >&2
			exit 1
			;;
	esac
}

usage()
{
	cat <<EOF
Usage: $0 <command> [value]

Commands:
  install
  uninstall
  status
  info
  test <protocolCode>
  on
  off
  temp <value>
  dwhtemp <value>
  setdwhtemp <value>
  silent <ON|OFF>
  mode <heat|cool|auto>
EOF
}

mkdir -p "$cache_dir"

username=$(setting username)
password=$(setting password)
mqtt=$(setting mqttserver)
mqttuser=$(setting mqttuser)
mqttpass=$(setting mqttpass)
mqttport=$(setting mqttport)
name=$(setting hassname)
password_hash=$(hash_password "$password")
protocol_codes_json=""
token=""
device=""

command="${1:-}"
value="${2:-}"

case "$command" in
	install)
		install_entities
		;;
	uninstall)
		uninstall_entities
		;;
	status)
		ensure_auth
		publish_status
		;;
	info)
		ensure_auth
		publish_info
		;;
	test)
		require_setting "$value" "protocolCode"
		ensure_auth
		test_protocol "$value"
		;;
	on)
		ensure_auth
		set_protocol "Power" "1"
		;;
	off)
		ensure_auth
		set_protocol "Power" "0"
		;;
	temp)
		require_setting "$value" "temperature"
		ensure_auth
		set_protocol "R02" "$value"
		;;
	dwhtemp|setdwhtemp)
		require_setting "$value" "DWH temperature"
		ensure_auth
		set_protocol "R01" "$value"
		;;
	silent)
		require_setting "$value" "silent mode"
		ensure_auth
		set_silent "$value"
		;;
	mode)
		require_setting "$value" "mode"
		ensure_auth
		set_mode "$value"
		;;
	*)
		usage
		exit 1
		;;
esac
